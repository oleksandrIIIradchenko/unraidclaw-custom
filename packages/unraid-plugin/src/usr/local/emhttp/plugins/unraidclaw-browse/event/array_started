#!/bin/bash
# Auto-start unraidclaw when array starts (if enabled)
CONFIG="/boot/config/plugins/unraidclaw-browse/unraidclaw-browse.cfg"
if [ -f "$CONFIG" ]; then
  SERVICE=$(grep -oP 'SERVICE="\K[^"]+' "$CONFIG")
  if [ "$SERVICE" = "enable" ]; then
    /etc/rc.d/rc.unraidclaw-browse start
  fi
fi
